$bg:             #1a1b26;
$surface:        #24283b;
$border:         #414868;
$border-active:  #7aa2f7;
$text:           #a9b1d6;
$text-dim:       #8892b5;
$highlight-bg:   #364a82;
$highlight-text: #c0caf5;
$err:            #f7768e;
$cyan:           #7dcfff;

Screen {
    layers: base modal;
    background: $bg;
    color: $text;
}

/* ── Main layout ─────────────────────────── */

#main-layout {
    height: 1fr;
}

#record-panel {
    width: 32;
    border: solid $border;
    border-title-color: $border-active;
    border-title-align: left;
}

#record-panel:focus-within {
    border: solid $border-active;
}

#detail-panel {
    width: 1fr;
    border: solid $border;
    border-title-color: $border-active;
    border-title-align: left;
}

#detail-panel:focus-within {
    border: solid $border-active;
}

/* ── ListView ────────────────────────────── */

ListView {
    background: transparent;
    border: none;
    padding: 0;
}

ListView:focus {
    border: none;
}

ListItem {
    padding: 0 1;
    background: transparent;
    color: $text;
}

ListItem.--highlight {
    background: $highlight-bg;
    color: $highlight-text;
}

/* ── Detail content ──────────────────────── */

#detail-name {
    margin: 1 2 0 2;
}

#detail-value {
    margin: 0 2 0 2;
}


/* ── Footer ──────────────────────────────── */

Footer {
    background: $surface;
    color: $text-dim;
}

/* ── Inputs ──────────────────────────────── */

Input {
    background: transparent;
    border: none;
    border-bottom: solid $border;
    color: $text;
    height: 3;
    padding: 1 0 0 0;
}

Input:focus {
    border: none;
    border-bottom: solid $border-active;
}

/* ── Buttons ─────────────────────────────── */

Button {
    background: $surface;
    border: none;
    color: $text;
    height: 1;
    min-width: 8;
    padding: 0 2;
}

Button:hover {
    background: $highlight-bg;
    color: $highlight-text;
}

Button:focus {
    background: $border-active;
    color: $bg;
    text-style: bold;
}

Button.-primary {
    background: #1a3a6e;
    color: $highlight-text;
    text-style: bold;
}

Button.-primary:hover {
    background: $highlight-bg;
}

Button.-primary:focus {
    background: $border-active;
    color: $bg;
    text-style: bold;
}

Button.-error {
    background: #5a1f2f;
    color: $highlight-text;
    text-style: bold;
}

Button.-error:hover {
    background: #7a2d42;
}

Button.-error:focus {
    background: $err;
    color: $bg;
    text-style: bold;
}

/* ── Unlock screen ───────────────────────── */

UnlockScreen {
    align: center middle;
    background: $bg;
}

#unlock-dialog {
    width: 52;
    height: auto;
    padding: 1 2;
    border: solid $border-active;
    background: $surface;
    border-title-color: $border-active;
    border-title-align: left;
}

.field-label {
    margin-top: 1;
    color: $text-dim;
}

#unlock-error {
    min-height: 1;
    color: $err;
    margin-top: 1;
}

#unlock-buttons {
    height: auto;
    align-horizontal: right;
    margin-top: 1;
}

#unlock-buttons Button {
    margin-left: 1;
}

/* ── Add record dialog ───────────────────── */

AddRecordScreen {
    align: center middle;
    background: $bg 75%;
}

#add-record-dialog {
    width: 64;
    height: auto;
    padding: 1 2;
    border: solid $border-active;
    background: $surface;
    border-title-color: $border-active;
    border-title-align: left;
}

/* ── Record type tabs ────────────────────── */

#record-tabs {
    height: auto;
}

#record-tabs ContentSwitcher {
    height: auto;
}

#record-tabs Tabs {
    background: transparent;
}

#record-tabs Tab {
    color: $text-dim;
}

#record-tabs Tab.-active {
    color: $highlight-text;
    text-style: bold;
}

#record-tabs TabPane {
    padding: 0 1 1 1;
    height: auto;
}

/* ── Complex credential builder ──────────── */

#complex-fields {
    height: auto;
}

.complex-field-row {
    height: auto;
    margin-top: 1;
}

.complex-field-row .field-label-input {
    width: 18;
}

.complex-field-row .field-value-input {
    width: 1fr;
    margin-left: 1;
}

.complex-field-row .field-secret-toggle {
    width: auto;
    height: 3;
    margin-left: 1;
    padding: 1 0 0 0;
    background: transparent;
    border: none;
    color: $text-dim;
}

.complex-field-row .field-secret-toggle:focus {
    color: $highlight-text;
    text-style: bold;
}

.complex-field-row .remove-field {
    margin-left: 1;
    min-width: 3;
    width: 3;
    height: 3;
    padding: 1 0 0 0;
}

#add-field {
    margin-top: 1;
}

#record-error {
    min-height: 1;
    color: $err;
    margin-top: 1;
}

#record-value-row {
    height: auto;
}

#record-value-row Input {
    width: 1fr;
}

#record-value-row Button {
    margin-left: 1;
    min-width: 3;
    width: 3;
    height: 3;
    padding: 1 0 0 0;
}

#record-buttons {
    height: auto;
    align-horizontal: right;
    margin-top: 1;
}

#record-buttons Button {
    margin-left: 1;
}

/* ── Confirm dialog ──────────────────────── */

ConfirmScreen {
    align: center middle;
    background: $bg 75%;
}

#confirm-dialog {
    width: 54;
    height: auto;
    padding: 1 2;
    border: solid $border-active;
    background: $surface;
    border-title-color: $border-active;
    border-title-align: left;
}

#confirm-message {
    margin: 1 0;
    color: $text;
}

#confirm-buttons {
    height: auto;
    align-horizontal: right;
    margin-top: 1;
}

#confirm-buttons Button {
    margin-left: 1;
}
